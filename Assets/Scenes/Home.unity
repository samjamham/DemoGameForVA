MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1100766350}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 24e42132fbbaf42479bf222e3511a4f5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: '::'
  CanInteract: 0
  MyLines:
  - Line: "<i>You!</i> Yes, you. Don\u2019t pretend you can\u2019t hear me. I have
      a job for you. Listen closely. There\u2019s a witch in the cave to the east
      of the <rotate=\"45\"><s>forest</s></rotate>."
    Terminator: 0
    Choises: []
  - Line: "She owes me a potion\u2026 I\u2019ve paid her handsomely and she\u2019s
      not replying to my letters. "
    Terminator: 0
    Choises: []
  - Line: "I need you to go and check on her, make sure she\u2019s not run off with
      the gold and left this kingdom in the dust.  "
    Terminator: 0
    Choises: []
  - Line: "I\u2019ve chosen you because\u2026 well, everyone else here is miserably
      useless. longingling Apart from my wonderful guard\u2026 She\u2019s not leaving
      my side.  "
    Terminator: 0
    Choises: []
  - Line: "Anyway. Off you go. I\u2019ll make it worth your while. "
    Terminator: 0
    Choises: []
  ID: 10
  MyFontAsset: {fileID: 11400000, guid: 26f81f9722cff6b4fa0c89df3c9f29c8, type: 2}
  MyName: ??????
